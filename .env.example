# consent-protocol/.env.example
# Copy to .env and replace placeholder values.
# Profile workflow:
# - Bootstrap local profile files from templates + cloud secrets:
#   bash ../scripts/env/bootstrap_profiles.sh
# - Create one of: .env.dev.local / .env.uat.local / .env.prod.local (local only)
# - Activate profile: bash ../scripts/env/use_profile.sh dev|uat|prod [--confirm-prod-local]
# - Committed templates: .env.dev.local.example, .env.uat.local.example, .env.prod.local.example

# Server port (optional if not running web server)
PORT=3000

# HMAC signing key (64-character hex, 256-bit)
SECRET_KEY=replace_with_64_char_hex_secret_key

# Vault AES encryption key (64-character hex, 256-bit)
VAULT_ENCRYPTION_KEY=replace_with_64_char_hex_vault_encryption_key

# Expiration durations (milliseconds)
DEFAULT_CONSENT_TOKEN_EXPIRY_MS=604800000
DEFAULT_TRUST_LINK_EXPIRY_MS=2592000000

# App context
ENVIRONMENT=development
AGENT_ID=agent_hushh_local
HUSHH_HACKATHON=enabled
APP_REVIEW_MODE=false
OTEL_ENABLED=false
# REVIEWER_EMAIL=
# REVIEWER_PASSWORD=

FRONTEND_URL=http://localhost:3000

# Vault write client version gate
MIN_VAULT_WRITE_CLIENT_VERSION=2.0.0
ENFORCE_VAULT_WRITE_CLIENT_VERSION=true

# Optional override: comma-separated passkey RP IDs allowed by backend validation.
# If omitted, backend derives allowlist from FRONTEND_URL + CORS_ALLOWED_ORIGINS.
# Set explicitly only when you need stricter/manual control.
# PASSKEY_ALLOWED_RP_IDS=localhost,127.0.0.1,kai.hushh.ai,hushh-webapp-1006304528804.us-central1.run.app

# Supabase Session Pooler Connection
DB_USER=postgres.your_project_ref
DB_PASSWORD=replace_with_db_password
DB_HOST=aws-1-us-east-1.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres

# Google Generative AI / Vertex AI
GOOGLE_API_KEY=replace_with_google_api_key
GOOGLE_GENAI_USE_VERTEXAI=True

# MCP Developer Token (for testing without Firebase)
MCP_DEVELOPER_TOKEN=replace_with_mcp_developer_token

# Kai finance-root migration / reset test context (local only)
KAI_TEST_USER_ID=replace_with_test_user_id
KAI_TEST_PASSPHRASE=replace_with_test_passphrase
KAI_TEST_BROKERAGE_PDF_PATH=data/brokerage_statements/Brokerage_March2021.pdf
KAI_TEST_ONBOARDING_INVESTMENT_HORIZON=short_term
KAI_TEST_ONBOARDING_DRAWDOWN_RESPONSE=reduce
KAI_TEST_ONBOARDING_VOLATILITY_PREFERENCE=small

FIREBASE_SERVICE_ACCOUNT_JSON=__FIREBASE_SERVICE_ACCOUNT_JSON__
# Optional auth-specific Firebase Admin credential for ID token verification.
# If unset, backend falls back to FIREBASE_SERVICE_ACCOUNT_JSON.
FIREBASE_AUTH_SERVICE_ACCOUNT_JSON=__FIREBASE_AUTH_SERVICE_ACCOUNT_JSON__

FINNHUB_API_KEY=replace_with_finnhub_api_key

PMP_API_KEY=replace_with_pmp_api_key

# Data health observability thresholds (Cloud Scheduler job)
OBS_DATA_STALE_RATIO_THRESHOLD=0.25

# Verification provider gateway (fail-closed if not configured)
FINRA_VERIFY_BASE_URL=
FINRA_VERIFY_API_KEY=
FINRA_VERIFY_TIMEOUT_SECONDS=5

# Backend local profile: development
# Copy to consent-protocol/.env.dev.local and set real local values.

# ---------------------------------------------------------------------------
# Core runtime (canonical)
# ---------------------------------------------------------------------------
ENVIRONMENT=development
PORT=8000
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
GOOGLE_GENAI_USE_VERTEXAI=False
OTEL_ENABLED=false

# ---------------------------------------------------------------------------
# Security and auth (required)
# ---------------------------------------------------------------------------
SECRET_KEY=replace_with_local_secret_key
VAULT_ENCRYPTION_KEY=replace_with_64_char_hex_vault_key
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"replace"}
# Optional auth-only Firebase Admin credential. Falls back to FIREBASE_SERVICE_ACCOUNT_JSON.
FIREBASE_AUTH_SERVICE_ACCOUNT_JSON=
APP_REVIEW_MODE=false
REVIEWER_UID=
MCP_DEVELOPER_TOKEN=replace_with_local_mcp_developer_token

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=replace_with_local_db_password

# ---------------------------------------------------------------------------
# AI/providers
# ---------------------------------------------------------------------------
GOOGLE_API_KEY=replace_with_google_api_key
FINNHUB_API_KEY=
PMP_API_KEY=

# ---------------------------------------------------------------------------
# Runtime options
# ---------------------------------------------------------------------------
CONSENT_SSE_ENABLED=false
SYNC_REMOTE_ENABLED=false
DEVELOPER_API_ENABLED=false
OBS_DATA_STALE_RATIO_THRESHOLD=0.25

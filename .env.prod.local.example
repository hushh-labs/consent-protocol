# Backend local profile: production simulation (config shape only)
# Copy to consent-protocol/.env.prod.local and set values only when needed.
# Treat this profile as read-only simulation unless explicitly approved.

# ---------------------------------------------------------------------------
# Core runtime (canonical)
# ---------------------------------------------------------------------------
ENVIRONMENT=production
PORT=8000
FRONTEND_URL=https://kai.hushh.ai
CORS_ALLOWED_ORIGINS=https://kai.hushh.ai
GOOGLE_GENAI_USE_VERTEXAI=True
OTEL_ENABLED=true

# ---------------------------------------------------------------------------
# Security and auth (required)
# ---------------------------------------------------------------------------
SECRET_KEY=replace_with_production_secret_key
VAULT_ENCRYPTION_KEY=__SET_VAULT_KEY__
FIREBASE_SERVICE_ACCOUNT_JSON=__FIREBASE_SERVICE_ACCOUNT_JSON__
FIREBASE_AUTH_SERVICE_ACCOUNT_JSON=__FIREBASE_AUTH_SERVICE_ACCOUNT_JSON__
APP_REVIEW_MODE=false
REVIEWER_UID=replace_with_reviewer_uid_if_used
MCP_DEVELOPER_TOKEN=replace_with_prod_mcp_developer_token

# ---------------------------------------------------------------------------
# Database (production shape)
# ---------------------------------------------------------------------------
DB_HOST=replace_with_prod_db_host
DB_PORT=5432
DB_NAME=postgres
DB_USER=replace_with_prod_db_user
DB_PASSWORD=replace_with_prod_db_password

# ---------------------------------------------------------------------------
# AI/providers
# ---------------------------------------------------------------------------
GOOGLE_API_KEY=replace_with_prod_google_api_key
FINNHUB_API_KEY=
PMP_API_KEY=

# ---------------------------------------------------------------------------
# Runtime options
# ---------------------------------------------------------------------------
CONSENT_SSE_ENABLED=false
SYNC_REMOTE_ENABLED=false
DEVELOPER_API_ENABLED=false
OBS_DATA_STALE_RATIO_THRESHOLD=0.25
